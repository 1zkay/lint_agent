# ── LLM 接入（选择一种，其余注释掉）───────────────────────────────

# OpenRouter（OpenAI 兼容接口）
LLM_MODEL=openai:google/gemini-3-flash-preview
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your api key

# 硅基流动（OpenAI 兼容接口）
# LLM_MODEL=openai:Pro/zai-org/GLM-5
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=your key

# 前端可切换模型预设：如果沿用同一兼容接口和密钥，只继续添加模型行即可
# LLM_MODEL_2=openai:Qwen/Qwen3.5-397B-A17B
# LLM_MODEL_3=openai:deepseek-ai/DeepSeek-V3.2

# 本地 Ollama（无需 API Key）
# LLM_MODEL=ollama:qwen3.5:9b
# LLM_BASE_URL=http://localhost:11434

# 本地 llama.cpp（无需 API Key）
# LLM_MODEL=openai:qwen3.6-35b-a3b
# LLM_BASE_URL=http://0.0.0.0:8080
# LLM_API_KEY=llama


# LLM 生成参数（通常无需修改）
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=40960
LLM_TIMEOUT=1200
LLM_REASONING=false


# ── Agentic RAG（IEEE standard PDF）──────────────────────────────
RAG_ENABLED=true
RAG_PDF_PATHS=../ieee_standard.pdf;../vivado-synthesis.pdf
# 默认知识库 PDF：<repo>/ieee_standard.pdf
# 单 PDF 和多 PDF 统一使用这个配置；单文档时只写一个路径即可
# 默认索引目录会根据当前 RAG_EMBED_MODEL 自动推导：
#   <repo>/rag_index_hardware_references_<embedding_model_slug>
# RAG_INDEX_DIR=
RAG_EMBED_MODEL=qwen/qwen3-embedding-8B
# 留空时复用 LLM_BASE_URL / LLM_API_KEY；当前默认即 OpenRouter
# RAG_EMBED_BASE_URL=
# RAG_EMBED_API_KEY=
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5
RAG_MIN_RELEVANCE=0.30
RAG_MAX_REWRITES=1
RAG_EMBED_BATCH_SIZE=64


# ── Agent 中间件 / Plan-and-Execute ────────────────────────────────
# TodoListMiddleware: 规划模块（为 Agent 注入 write_todos 工具）
AGENT_ENABLE_TODO=true
# SummarizationMiddleware: 长对话摘要压缩，防止 context 溢出
AGENT_ENABLE_SUMMARIZATION=true
AGENT_SUMMARIZATION_TRIGGER_TOKENS=128000
AGENT_SUMMARIZATION_KEEP_MESSAGES=20
# ReflectionMiddleware: LLM 响应反思评估（Evaluator-Optimizer 模式）
# 对纯文本响应进行质量评估，不通过则注入反馈重试
AGENT_ENABLE_REFLECTION=false
AGENT_REFLECTION_MAX=1
# ModelRetryMiddleware: 模型调用失败自动重试（指数退避）
# 保守配置：底层模型 SDK 已有网络/API 层重试，这里默认只做 1 次 Agent 模型节点级重试
AGENT_ENABLE_MODEL_RETRY=true
AGENT_MODEL_RETRY_MAX=4
# ToolRetryMiddleware: 工具调用失败自动重试（指数退避）
AGENT_ENABLE_TOOL_RETRY=true
AGENT_TOOL_RETRY_MAX=4
# Tavily 联网搜索（每月 1000 次免费）
TAVILY_API_KEY=your key
# ShellToolMiddleware: 持久化命令行工具（官方标准实现）
# 为 Agent 注入 shell 工具，可在持久 shell 会话中执行命令
AGENT_ENABLE_SHELL=true
# 工作目录
SHELL_WORKSPACE_ROOT=
# 单条命令超时（秒）
SHELL_COMMAND_TIMEOUT=3000
# 输出最大行数（超出截断）
SHELL_MAX_OUTPUT_LINES=200
# SkillsMiddleware: 基于 Agent Skills 标准的渐进式领域知识加载
# 通过 deepagents.middleware.skills 实现，使用 FilesystemBackend 读取真实文件系统
AGENT_ENABLE_SKILLS=true
# 逗号分隔的 skills 目录列表（相对路径时按 Chainlit 启动 CWD 解析），每个目录下放 skill-name/SKILL.md
AGENT_SKILLS_DIRS=/skills
# HumanInTheLoopMiddleware: 高风险工具执行前需用户审批
AGENT_TOOL_APPROVAL_ENABLED=false
AGENT_HITL_TIMEOUT=600
# Agent 最大递归步数
AGENT_RECURSION_LIMIT=1000

# ── LangGraph Checkpointer（PostgreSQL 标准实现）───────────────────
# postgres: 使用 PostgreSQL 持久化；memory: 仅内存（调试/回退）
CHECKPOINTER_BACKEND=postgres
CHECKPOINTER_DB_URI=postgresql://postgres:123456@127.0.0.1:5432/langgraph_db
# 首次使用 postgres 时自动创建表结构
CHECKPOINTER_AUTO_SETUP=true

# Long-term memory: LangGraph store (cross-thread / cross-session)
MEMORY_STORE_BACKEND=postgres
MEMORY_STORE_DB_URI=postgresql://postgres:123456@127.0.0.1:5432/langgraph_db
MEMORY_STORE_AUTO_SETUP=true
MEMORY_ENABLE_SEMANTIC_SEARCH=true
MEMORY_EMBED_MODEL=qwen/qwen3-embedding-8B
# Leave blank to reuse RAG_EMBED_BASE_URL / RAG_EMBED_API_KEY
# MEMORY_EMBED_BASE_URL=
# MEMORY_EMBED_API_KEY=
# pgvector vector indexes support up to 2000 dims, so force memory embeddings to 1536
MEMORY_EMBED_DIMS=1536

# ── Chainlit 历史会话（官方要求：认证 + 数据持久化）────────────────
# 1) 启用密码认证后，历史会话列表/恢复入口才可用
CHAINLIT_ENABLE_PASSWORD_AUTH=true
CHAINLIT_AUTH_USERNAME=zk
CHAINLIT_AUTH_PASSWORD=123456
# 2) 启用 Chainlit 默认数据层（官方标准）
DATABASE_URL=postgresql://postgres:123456@127.0.0.1:5432/chainlit_db
# 3) 认证开启时还需要 JWT 密钥，可用 `chainlit create-secret` 生成
CHAINLIT_AUTH_SECRET=0.ldvP%8pAhSdFNNkipRrcS1Wom~ci.Z*Y2AQxA5CvRzTaOBEO>_xb0UYeb6rhum

# ── Chainlit 附件对象存储（容器内 MinIO）───────────────────────────
BUCKET_NAME=chainlit-files
APP_AWS_ACCESS_KEY=minioadmin
APP_AWS_SECRET_KEY=minioadmin123
APP_AWS_REGION=us-east-1
DEV_AWS_ENDPOINT=http://127.0.0.1:9000

# ── OpenRouter 兼容（使用 OpenRouter 时可选）─────────────────────
OPENROUTER_REFERER=https://github.com/alint-pro
OPENROUTER_TITLE=ALINT-PRO Analysis

# -- LangSmith tracing -------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your key
LANGSMITH_PROJECT=lint
